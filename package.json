{
  "name": "jjworld-website",
  "version": "1.0.0",
  "description": "JJ WORLD 화장품 브랜드 공식 홈페이지",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --r2=R2 --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist --r2=R2",
    "deploy": "npm run build && wrangler pages deploy dist --project-name jjworld",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000"
  },
  "keywords": ["jjworld", "cosmetics", "beauty", "cloudflare-pages"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@hono/vite-cloudflare-pages": "^0.4.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wrangler": "^4.70.0"
  }
}
